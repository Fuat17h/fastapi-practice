{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Uvicorn (port 8001)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8001", "--host", "127.0.0.1"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
